---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- ══════════════════════════════════════════════════
       NAV — logo · pill center · cta right
       ══════════════════════════════════════════════════ -->
  <nav id="ll-nav">
    <a href="/" class="nav-logo">
      <img src="/assets/logo.svg" alt="HORS KADR" />
      <span class="nav-logo-sep"></span>
      <span class="nav-logo-sub">LayLabo</span>
    </a>
    <div class="nav-pill">
      <a href="#problemes">Problèmes Gasy</a>
      <a href="#solutions">Nos Solutions</a>
      <a href="#projets">Projets</a>
      <a href="#vision">Vision</a>
      <a href="#contact">Contact</a>
    </div>
    <a href="https://horskadr.mg" class="nav-cta">horskadr.mg ↗</a>
  </nav>

  <!-- ══════════════════════════════════════════════════
       HERO — centré + floating UI cards (template style)
       ══════════════════════════════════════════════════ -->
  <header class="hero" id="hero">
    <!-- Background blobs -->
    <div class="hero-blob" id="blob1"></div>
    <div class="hero-blob-2"></div>

    <!-- ✦ star decos -->
    <span class="star" style="top:22%;left:22%;font-size:16px" id="star1">✦</span>
    <span class="star" style="top:68%;left:20%;font-size:11px" id="star2">✦</span>
    <span class="star" style="top:28%;right:22%;font-size:10px" id="star3">✦</span>
    <span class="star" style="bottom:20%;right:20%;font-size:14px" id="star4">✦</span>

    <!-- ══ Bulles flottantes — uniformes, problème → solution ══ -->

    <!-- 1 · Santé / médecin -->
    <div class="bubble b1" id="b1">
      <div class="bubble-prob"><span class="bdot bdot-red"></span>Pas de médecin disponible aux alentours</div>
      <div class="bubble-sol"><span class="bdot bdot-green"></span>Liste des médecins accessibles sans réservation</div>
    </div>

    <!-- 2 · Courses / livraison -->
    <div class="bubble b2" id="b2">
      <div class="bubble-prob"><span class="bdot bdot-red"></span>Férié, où faire ses courses ?</div>
      <div class="bubble-sol"><span class="bdot bdot-green"></span>Ce sera livré dans 20 min 🛵</div>
    </div>

    <!-- 3 · Transport / bus -->
    <div class="bubble b3" id="b3">
      <div class="bubble-prob"><span class="bdot bdot-red"></span>Plus de bus ? Il a fait demi-tour ?</div>
      <div class="bubble-sol"><span class="bdot bdot-green"></span>Votre bus dans 13 min 🚌</div>
    </div>

    <!-- 4 · Urgence / ambulance -->
    <div class="bubble b4" id="b4">
      <div class="bubble-prob"><span class="bdot bdot-red"></span>Il fait nuit, pas moyen d'aller à l'hôpital</div>
      <div class="bubble-sol"><span class="bdot bdot-green"></span>L'ambulance privée arrive dans 7 min 🚑</div>
    </div>

    <!-- 5 · Lifestyle / rooftop -->
    <div class="bubble b5" id="b5">
      <div class="bubble-prob"><span class="bdot bdot-red"></span>Où sont les beaux spots ici ?</div>
      <div class="bubble-sol"><span class="bdot bdot-green"></span>Selon 7K avis, c'est dans ce rooftop ✨</div>
    </div>

    <!-- 6 · Embouteillage -->
    <div class="bubble b6" id="b6">
      <div class="bubble-prob"><span class="bdot bdot-red"></span>Peur d'arriver en retard à un RDV</div>
      <div class="bubble-sol"><span class="bdot bdot-green"></span>⚠️ Embouteillage 2h29 · Ankorondrano → Analakely</div>
    </div>

    <!-- 7 · Hôtel last minute (écrans larges) -->
    <div class="bubble b7" id="b7">
      <div class="bubble-prob"><span class="bdot bdot-red"></span>L'hôtel encore non rempli en ce dernier moment ?</div>
      <div class="bubble-sol"><span class="bdot bdot-green"></span>Chez eux à 5 min à pied de l'océan 🌊</div>
    </div>

    <!-- 8 · Petite main / linge (écrans larges) -->
    <div class="bubble b8" id="b8">
      <div class="bubble-prob"><span class="bdot bdot-red"></span>Qui lave nos linges dans ce quartier ?</div>
      <div class="bubble-sol"><span class="bdot bdot-green"></span>3 personnes ont postulé 🙌</div>
    </div>

    <!-- ── Central content ── -->
    <div class="hero-center">
      <div class="hero-eyebrow reveal">
        <span class="dot"></span>
        <span>LayLabo — Le mouton noir de l'innovation malagasy</span>
      </div>

      <h1 class="hero-title reveal d1">
        Les solutions<br />
        <span class="ht-ghost">digitales</span>
        à portée<br />
        <span class="accent">de main.</span>
      </h1>

      <p class="hero-sub reveal d2">
        LayLabo conçoit des <b>produits digitaux utiles</b> et pensés pour les Malagasy.
        Chaque app répond à un vrai problème de tous les jours.
      </p>

      <div class="hero-cta reveal d3">
        <a href="#projets" class="btn-primary">Voir nos projets →</a>
        <a href="#contact" class="btn-ghost">Devenir partenaire</a>
      </div>
    </div>
  </header>

  <!-- ── Sectors press bar ── -->
  <div class="press-bar">
    <div class="wrap">
      <div class="press-inner">
        <span class="press-label">Secteurs couverts</span>
        <span class="press-divider"></span>
        <span class="press-tag">Santé</span>
        <span class="press-tag">Éducation</span>
        <span class="press-tag">Transport</span>
        <span class="press-tag">Commerce</span>
        <span class="press-tag">Hygiène</span>
        <span class="press-tag">Lifestyle</span>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════
       MARQUEE
       ══════════════════════════════════════════════════ -->
  <div class="marquee" aria-hidden="true">
    <div class="track">
      <span>Ho an'ny Malagasy</span><span class="sep"> ✦ </span>
      <span>Le mouton noir de l'innovation</span><span class="sep"> ✦ </span>
      <span>HORS KADR</span><span class="sep"> ✦ </span>
      <span>L'Impact</span><span class="sep"> ✦ </span>
      <span>Vita Malagasy</span><span class="sep"> ✦ </span>
      <span>Ho an'ny Malagasy</span><span class="sep"> ✦ </span>
      <span>Le mouton noir de l'innovation</span><span class="sep"> ✦ </span>
      <span>HORS KADR</span><span class="sep"> ✦ </span>
      <span>L'Impact</span><span class="sep"> ✦ </span>
      <span>Vita Malagasy</span><span class="sep"> ✦ </span>
      <span>Ho an'ny Malagasy</span><span class="sep"> ✦ </span>
      <span>Le mouton noir de l'innovation</span><span class="sep"> ✦ </span>
      <span>HORS KADR</span><span class="sep"> ✦ </span>
      <span>L'Impact</span><span class="sep"> ✦ </span>
      <span>Vita Malagasy</span><span class="sep"> ✦ </span>
      <span>Ho an'ny Malagasy</span><span class="sep"> ✦ </span>
      <span>Le mouton noir de l'innovation</span><span class="sep"> ✦ </span>
      <span>HORS KADR</span><span class="sep"> ✦ </span>
      <span>L'Impact</span><span class="sep"> ✦ </span>
      <span>Vita Malagasy</span><span class="sep"> ✦ </span>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════
       STATS BAR
       ══════════════════════════════════════════════════ -->
  <section class="stats-bar">
    <div class="wrap">
      <div class="stats-inner reveal">
        <div class="stat-item">
          <span class="stat-val">1</span>
          <span class="stat-label">Produits en dev</span>
        </div>
        <div class="stat-item">
          <span class="stat-val">+6</span>
          <span class="stat-label">Secteurs ciblés</span>
        </div>
        <div class="stat-item">
          <span class="stat-val">100%</span>
          <span class="stat-label">Vita Gasy</span>
        </div>
        <div class="stat-item">
          <span class="stat-val">2025</span>
          <span class="stat-label">Lancement</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════
       01 — PROBLÈME GASY
       ══════════════════════════════════════════════════ -->
  <section class="sec" id="problemes">
    <div class="wrap">
      <div class="seclabel">
        <span class="idx">01</span>
        <span>Les problèmes</span>
        <span class="mg">— Ny olana tsikaritra</span>
        <span class="fill"></span>
      </div>

      <h2 class="h2-disp reveal">
        Ce que vivent<br />
        vraiment les <span class="accent">Malagasy.</span>
      </h2>
      <p class="sec-intro reveal d1">
        Avant de coder une seule ligne, on écoute. On observe. Et ce qu'on voit,
        c'est un écart béant entre les besoins réels et les outils disponibles.
      </p>

      <div class="problem-grid">

        <!-- 1 — Santé -->
        <div class="problem-card reveal">
          <div class="problem-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
          </div>
          <h3 class="problem-title">Soins inaccessibles</h3>
          <p class="problem-desc">
            Se soigner n'est pas accessible aujourd'hui. Même juste le fait de savoir où consulter, où est le médecin ou la pharmacie la plus proche, combien ça peut coûter d'y aller.
          </p>
          <div class="problem-stat">70%</div>
          <div class="problem-stat-sub">sans accès à des soins adaptés</div>
        </div>

        <!-- 2 — Éducation -->
        <div class="problem-card reveal d1">
          <div class="problem-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
              <path d="M6 12v5c3 3 9 3 12 0v-5"/>
            </svg>
          </div>
          <h3 class="problem-title">Éducation à deux vitesses</h3>
          <p class="problem-desc">
            Les ressources pédagogiques malagasy existent mais restent difficiles d'accès. Les programmes sont figés depuis des années pendant que les compétences nécessaires dans ce monde qui évolue ne cessent de changer.
          </p>
          <div class="problem-stat">89%</div>
          <div class="problem-stat-sub">des jeunes malagasy sur les réseaux sociaux, mais sans contenu éducatif adapté</div>
        </div>

        <!-- 3 — Transport -->
        <div class="problem-card reveal d2">
          <div class="problem-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h3 class="problem-title">Transport chaotique</h3>
          <p class="problem-desc">
            Pas d'info en temps réel sur les embouteillages, routes coupées, accidents, bus. Pas d'application. Juste de l'incertitude à chaque trajet dans les grandes villes. Du temps perdu à chaque déplacement.
          </p>
          <div class="problem-stat">2h+</div>
          <div class="problem-stat-sub">perdues en déplacements chaque jour</div>
        </div>

        <!-- 4 — Commerce -->
        <div class="problem-card reveal">
          <div class="problem-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2 3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 01-8 0"/>
            </svg>
          </div>
          <h3 class="problem-title">Commerce sans vitrine</h3>
          <p class="problem-desc">
            Des milliers de créateurs et vendeurs talentueux, invisibles en ligne. Pas de caisse numérique, pas de gestion en temps réel pour détecter les pertes, pas de clients au-delà de leur quartier.
          </p>
          <div class="problem-stat">85%</div>
          <div class="problem-stat-sub">des commerces sans outil digital</div>
        </div>

        <!-- 5 — Hygiène -->
        <div class="problem-card reveal d1">
          <div class="problem-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="problem-title">Hygiène & santé publique</h3>
          <p class="problem-desc">
            Les bonnes pratiques ne sont pas vulgarisées là où elles comptent. Les outils d'éducation et de suivi manquent à tous les niveaux.
          </p>
          <div class="problem-stat">40%</div>
          <div class="problem-stat-sub">de foyers sans accès à l'info sanitaire</div>
        </div>

        <!-- 6 — Emploi -->
        <div class="problem-card reveal d2">
          <div class="problem-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 00-3-3.87"/>
              <path d="M16 3.13a4 4 0 010 7.75"/>
            </svg>
          </div>
          <h3 class="problem-title">Emploi fragmenté</h3>
          <p class="problem-desc">
            Des super talents locaux qui ne savent pas comment obtenir les opportunités. CVs perdus dans des boîtes mail. Offres invisibles. Le marché tourne à 20% de son potentiel.
          </p>
          <div class="problem-stat">60%</div>
          <div class="problem-stat-sub">des jeunes diplômés sous-employés</div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════
       02 — NOS SOLUTIONS
       ══════════════════════════════════════════════════ -->
  <section class="sec" id="solutions">
    <div class="wrap">
      <div class="seclabel">
        <span class="idx">02</span>
        <span>Nos solutions</span>
        <span class="mg">— Vahaolana</span>
        <span class="fill"></span>
      </div>

      <div class="solutions-intro">
        <div>
          <h2 class="h2-disp reveal">
            Notre réponse,<br />
            produit par <span class="accent">produit.</span>
          </h2>
        </div>
        <div class="solutions-body reveal d1">
          <p>
            On ne fait pas des apps pour faire des apps. Chaque produit LayLabo
            part d'un <strong>problème réel</strong>, vécu par des <strong>gens réels</strong> —
            et on construit la <strong>solution la plus directe</strong> possible.
          </p>
          <p>
            Conçu à <strong>Antananarivo</strong>. Pensé pour le <strong>marché malgache</strong>.
            Construit pour <strong>durer</strong>.
          </p>
        </div>
      </div>

      <!-- ── Process WOVE style ── -->
      <div class="wove-wrap">

        <!-- Arc décoratif SVG -->
        <svg class="wove-bg-arc" viewBox="0 0 500 800" fill="none" aria-hidden="true">
          <circle cx="-60" cy="400" r="340" stroke="rgba(13,206,107,0.1)" stroke-width="1"/>
          <circle cx="-60" cy="400" r="240" stroke="rgba(13,206,107,0.06)" stroke-width="1" stroke-dasharray="3 9"/>
        </svg>

        <div class="wove-steps">

          <div class="wove-step" id="ws1">
            <div class="ws-track">
              <span class="ws-dot"></span>
            </div>
            <div class="ws-body">
              <div class="ws-num-bg" aria-hidden="true">01</div>
              <span class="ws-label">01</span>
              <h4 class="ws-title">Observer · Analyser · Écouter</h4>
              <p class="ws-desc">On part du terrain, pas d'une idée abstraite. On écoute les vrais utilisateurs avant de toucher au code.</p>
            </div>
          </div>

          <div class="wove-step" id="ws2">
            <div class="ws-track">
              <span class="ws-dot"></span>
            </div>
            <div class="ws-body">
              <div class="ws-num-bg" aria-hidden="true">02</div>
              <span class="ws-label">02</span>
              <h4 class="ws-title">MVP interne & Tests</h4>
              <p class="ws-desc">On construit vite, on teste vrai. On rate parfois — et c'est là qu'on apprend l'essentiel.</p>
            </div>
          </div>

          <div class="wove-step" id="ws3">
            <div class="ws-track">
              <span class="ws-dot"></span>
            </div>
            <div class="ws-body">
              <div class="ws-num-bg" aria-hidden="true">03</div>
              <span class="ws-label">03</span>
              <h4 class="ws-title">Itérer & Améliorer</h4>
              <p class="ws-desc">Ce que les utilisateurs nous disent compte plus que tout. Chaque retour devient une amélioration concrète.</p>
            </div>
          </div>

          <div class="wove-step wove-step--last" id="ws4">
            <div class="ws-track ws-track--last">
              <span class="ws-dot"></span>
            </div>
            <div class="ws-body">
              <div class="ws-num-bg" aria-hidden="true">04</div>
              <span class="ws-label">04</span>
              <h4 class="ws-title">Déployer pour l'impact</h4>
              <p class="ws-desc">Pour le maximum d'impact, pour le plus grand nombre. Vita Malagasy, déployé pour les Malagasy.</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════════
       03 — PROJETS — MARARY
       ══════════════════════════════════════════════════ -->
  <section class="sec sec-dark marary-sec" id="projets">
    <div class="wrap">
      <div class="seclabel">
        <span class="idx">03</span>
        <span>Projets</span>
        <span class="mg">— Tetikasa</span>
        <span class="fill"></span>
      </div>

      <div class="marary-showcase reveal">

        <!-- ── GAUCHE : texte + problème ── -->
        <div class="marary-left">

          <!-- Badge statut -->
          <div class="marary-status">
            <span class="dot"></span>
            <span>En développement · LayLabo 2025</span>
          </div>

          <!-- Nom app -->
          <h2 class="marary-name">MARARY</h2>
          <p class="marary-tagline">La santé, enfin à portée de main.</p>
          <p class="marary-desc">
            MARARY c'est l'app qui répond à la question que chaque Malagasy se pose :
            <strong>où consulter, qui, et combien ça coûte ?</strong><br /><br />
            Localisation des médecins et pharmacies à proximité, tarifs,
            disponibilité en temps réel, prise de RDV directe.
            Pour que se soigner ne soit plus un parcours du combattant.
          </p>

          <!-- Carte problème -->
          <div class="marary-problem">
            <div class="mp-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            </div>
            <div>
              <div class="mp-label">Le problème qu'on règle</div>
              <div class="mp-title">Soins inaccessibles</div>
              <p class="mp-text">Même savoir où est le médecin le plus proche ou combien ça coûte est impossible sans outil.</p>
              <div class="mp-stat">70% <span>sans accès à des soins adaptés</span></div>
            </div>
          </div>

          <a href="#contact" class="btn-primary" style="align-self:flex-start;margin-top:8px">Suivre MARARY →</a>

        </div>

        <!-- ── DROITE : visuel Karvon-style ── -->
        <div class="marary-visual">

          <div class="marary-bg-title" aria-hidden="true">MARARY</div>
          <div class="m-ring r1"></div>
          <div class="m-ring r2"></div>

          <!-- Grand badge circulaire rotatif -->
          <div class="m-text-circle">
            <svg viewBox="0 0 340 340" class="m-text-circle-svg">
              <defs><path id="mtc" d="M170,170 m-150,0 a150,150 0 1,1 300,0 a150,150 0 1,1 -300,0"/></defs>
              <text class="mtc-text"><textPath href="#mtc">être en bonne santé n'est pas facultatif · être en bonne santé n'est pas facultatif · </textPath></text>
            </svg>
            <div class="mtc-core">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
          </div>

          <!-- Phone image (fond blanc → transparent avec multiply) + map derrière -->
          <div class="marary-phone-wrap">

            <!-- MAP derrière l'image (z-index 1) — apparaît dans la zone blanche de l'écran -->
            <div class="marary-screen-map">
              <!-- Routes -->
              <svg class="mk-roads" viewBox="0 0 100 100" preserveAspectRatio="none">
                <line x1="0" y1="42" x2="100" y2="42" stroke="#e8e0d0" stroke-width="2.5"/>
                <line x1="0" y1="68" x2="100" y2="68" stroke="#e8e0d0" stroke-width="1.2"/>
                <line x1="0" y1="20" x2="100" y2="20" stroke="#e8e0d0" stroke-width="1"/>
                <line x1="30" y1="0"  x2="30"  y2="100" stroke="#e8e0d0" stroke-width="1.5"/>
                <line x1="60" y1="0"  x2="60"  y2="100" stroke="#e8e0d0" stroke-width="2.5"/>
                <line x1="82" y1="0"  x2="82"  y2="100" stroke="#e8e0d0" stroke-width="1"/>
                <line x1="0" y1="5"   x2="45"  y2="75"  stroke="#e8e0d0" stroke-width="1" opacity=".6"/>
                <line x1="55" y1="0"  x2="100" y2="60"  stroke="#e8e0d0" stroke-width="1" opacity=".6"/>
              </svg>
              <!-- Parcs -->
              <div class="mk-park" style="top:5%;left:62%;width:30%;height:28%;border-radius:40% 35% 45% 30%"></div>
              <div class="mk-park" style="top:64%;left:3%;width:20%;height:26%;border-radius:30% 45% 35% 40%"></div>
              <div class="mk-park" style="top:72%;left:65%;width:26%;height:20%;border-radius:35% 30% 40% 45%"></div>
              <!-- Rivière -->
              <svg class="mk-river" viewBox="0 0 100 100" preserveAspectRatio="none">
                <path d="M 58 0 Q 55 20 62 35 Q 68 50 60 65 Q 52 80 58 100" stroke="#90caf9" stroke-width="3" fill="none" opacity=".9"/>
              </svg>
              <!-- Labels quartiers -->
              <div class="mk-qlabel" style="top:10%;left:8%">ANALAKELY</div>
              <div class="mk-qlabel" style="top:50%;left:62%">AMPEFILOHA</div>
              <div class="mk-qlabel" style="top:72%;left:32%">ISOTRY</div>
              <!-- Avatars médecins -->
              <div class="mk-apin" style="top:16%;left:50%">
