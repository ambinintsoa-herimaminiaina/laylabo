<!-- ════════════════════════════════════════════════════════
     GSAP — hero floating cards + blobs + stars
     ════════════════════════════════════════════════════════ -->
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ── Blobs breathe ──────────────────────────────────────
  gsap.to('#blob1', {
    scale: 1.15, opacity: .8,
    duration: 6, ease: 'sine.inOut', repeat: -1, yoyo: true,
  });

  // ── Bulles flottantes — flottement ample comme BaseClub ──
  document.querySelectorAll<HTMLElement>('.bubble').forEach((el, i) => {
    const dir  = i % 2 === 0 ? 1 : -1;
    const yAmp = 16 + (i % 3) * 6;          // 16–28px selon la bulle
    const dur  = 2.4 + i * 0.38;

    // flottement Y ample
    gsap.to(el, {
      y: dir * yAmp,
      duration: dur,
      ease: 'sine.inOut', repeat: -1, yoyo: true,
    });
    // rotation oscillante légère ±1.2deg
    gsap.to(el, {
      rotate: `+=${dir * 1.2}`,
      duration: dur * 1.3,
      ease: 'sine.inOut', repeat: -1, yoyo: true,
    });
    // micro scale pour donner l'impression de profondeur
    gsap.to(el, {
      scale: 1.03,
      duration: dur * 1.7,
      ease: 'sine.inOut', repeat: -1, yoyo: true,
    });
  });

  // ── Stars rotate ───────────────────────────────────────
  ['#star1','#star2','#star3','#star4'].forEach((id, i) => {
    const el = document.querySelector<HTMLElement>(id);
    if (!el) return;
    gsap.to(el, {
      rotation: 360, duration: 9 + i * 2.5,
      ease: 'none', repeat: -1,
    });
  });

  // ── WOVE process steps — activation au scroll ─────────
  document.querySelectorAll<HTMLElement>('.wove-step').forEach((step) => {
    ScrollTrigger.create({
      trigger: step,
      start: 'top 68%',
      onEnter: () => step.classList.add('ws-active'),
      onEnterBack: () => step.classList.add('ws-active'),
      onLeaveBack: () => step.classList.remove('ws-active'),
    });
    // Ghost number glisse depuis la droite
    gsap.fromTo(
      step.querySelector('.ws-num-bg'),
      { x: 40, opacity: 0 },
      { x: 0, opacity: 1, duration: 0.9, ease: 'power3.out',
        scrollTrigger: { trigger: step, start: 'top 72%', once: true } }
    );
  });

  // ── Ambition numbers count up on scroll ───────────────
  document.querySelectorAll<HTMLElement>('.ambition-num').forEach((el) => {
    const raw  = el.textContent?.trim() ?? '';
    const suffix = raw.replace(/[\d.]/g, '');
    const num  = parseFloat(raw.replace(/[^\d.]/g, ''));
    if (isNaN(num)) return;
    const obj = { val: 0 };
    gsap.to(obj, {
      val: num, duration: 1.8, ease: 'power2.out',
      scrollTrigger: { trigger: el, start: 'top 88%', once: true },
      onUpdate() {
        const v = obj.val;
        el.textContent = (Number.isInteger(num) ? Math.round(v) : v.toFixed(1)) + suffix;
      },
    });
  });
</script>
